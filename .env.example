# Copy this file to .env and fill in the values before running the backend.

# Required: MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017

# Optional: database name (defaults to "astranotes")
MONGODB_DB=astranotes

# Optional: comma-separated allowed CORS origins (defaults to Vite dev server)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Phase 3 (Secure Notes) — required when encryption is enabled
# ENCRYPTION_KEY=<32-byte base64-encoded AES-256 key>
